# Deployment-specific configuration for wazuh-llm-triage.
#
# Copy to a gitignored `.env` and fill in your real values. These override the
# safe local-dev defaults in config/app_config.json. Never commit real private
# IPs or secrets — this repository may be public.
#
# Load them with one of:
#   set -a; source .env; set +a        # current shell
#   systemd unit:  EnvironmentFile=/path/to/.env
#
# ---------------------------------------------------------------------------
# Inference backends (run on a host with spare CPU/RAM reachable from the
# manager). Restrict the ports to the manager's IP; never expose them publicly.
OLLAMA_URL=http://YOUR_INFERENCE_HOST:11434
QDRANT_URL=http://YOUR_INFERENCE_HOST:6333

# Models served by Ollama on that host.
LLM_MODEL_NAME=qwen2.5:3b-instruct-q4_K_M
EMBEDDING_MODEL_NAME=all-minilm

# Qdrant collection name (optional; defaults to soc_knowledge).
# QDRANT_COLLECTION=soc_knowledge

# --- Triage behaviour (all optional; safe defaults shown) ---
# Minimum Wazuh rule.level to triage.
# MIN_ALERT_LEVEL=7
# Restrict triage to alerts in these rule.groups (comma-separated). Empty =
# triage every alert above MIN_ALERT_LEVEL. Recommended in production to avoid
# backing up on noisy Wazuh alerts.
# TRIAGE_RULE_GROUPS=anomaly_detector
# RAG fragments to retrieve, and per-request LLM timeout (seconds).
# RAG_TOP_K=5
# REQUEST_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# Wazuh manager — Phase 2+ (reading the live alert log on the manager itself).
# Leave unset during local simulation; defaults to data_ingest/live_alerts.json.
# WAZUH_ALERTS_PATH=/var/ossec/logs/alerts/alerts.json

# Re-inject triage verdicts back into Wazuh (Phase 2+) so they appear in the
# dashboard and drive escalation. Off by default.
# VERDICT_INJECTION_ENABLED=true
# WAZUH_SOCKET_PATH=/var/ossec/queue/sockets/queue

# ---------------------------------------------------------------------------
# Active Response (Phase 3) — DANGEROUS. Leave dry-run ON until you fully trust
# the verdicts. Real response runs ONLY when RESPONDER_DRY_RUN is explicitly
# "false"; anything else (unset / empty / typo) stays in safe dry-run.
# RESPONDER_DRY_RUN=true
# Only these command names may ever be dispatched (comma-separated). The LLM's
# free-text suggestion is never executed.
# RESPONDER_COMMAND_ALLOWLIST=firewall-drop
# RESPONDER_DEFAULT_COMMAND=firewall-drop
# Kill-switch: if this file exists, every active response is suppressed.
# KILL_SWITCH_FILE=/var/ossec/.llm_triage_KILL

# Wazuh API — only needed for REAL Active Response. The password is a secret.
# WAZUH_API_URL=https://127.0.0.1:55000
# WAZUH_API_USER=wazuh-wui
# WAZUH_API_PASSWORD=
# WAZUH_VERIFY_SSL=false
