#!/usr/bin/env bash
# Example deploy script. Copy to deploy.sh (gitignored) and set your own values.
# Pushes the code to the Wazuh manager host and rebuilds the container there.
set -euo pipefail

REMOTE=YOUR_MANAGER_HOST          # ssh host/alias of the Wazuh manager
DEST=/opt/wazuh-llm-triage        # install path on the manager

# Push code to the manager (rsync as root so it can write under /opt).
# Excludes local junk and secrets: .env (all your settings and secrets) stays on
# the server; knowledge_base/local/ (your private KB) is synced. The config is
# generic (env placeholders only), so it ships normally.
rsync -avz --delete --rsync-path="sudo rsync" \
  --exclude '.git/' --exclude 'venv/' --exclude '.venv/' --exclude '__pycache__/' \
  --exclude '.pytest_cache/' --exclude '.claude/' --exclude '.env' \
  --exclude 'data_ingest/live_alerts.json' \
  ./ "$REMOTE:$DEST/"

# Rebuild the image (picks up src/ changes) and (re)start the triage service.
ssh "$REMOTE" "cd $DEST && sudo docker compose up -d --build triage"
